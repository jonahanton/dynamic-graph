# Model provider: "openai" or "anthropic"
MODEL_PROVIDER=openai
OPENAI_MODEL=gpt-5.4
ANTHROPIC_MODEL=claude-sonnet-4-6

# Fill these in for a live run
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
BRAVE_API_KEY=
EXA_API_KEY=

# Local Langfuse stack (deploy/langfuse). Headless-provisioned keys.
LANGFUSE_PUBLIC_KEY=pk-lf-fg-local-public-0000000000
LANGFUSE_SECRET_KEY=sk-lf-fg-local-secret-0000000000
LANGFUSE_HOST=http://localhost:3800